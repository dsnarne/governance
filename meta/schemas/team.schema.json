{
  "type": "object",
  "required": [
    "name",
    "description",
    "maintainers",
    "contributors",
    "repos"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Used for any public-facing or display contexts (e.g. the GitHub team name)."
    },
    "website": {
      "type": "string",
      "format": "url",
      "description": "The website URL that will be deployed to."
    },
    "description": {
      "type": "string",
      "description": "A brief description of the team."
    },
    "repos": {
      "type": "array",
      "description": "The GitHub repositories of the team.",
      "items": {
        "type": "object",
        "required": [
          "slug",
          "description"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "membership": {
      "type": "array",
      "description": "List of membership records by timeframe.",
      "items": {
        "type": "object",
        "required": [
          "timeframe",
          "maintainers",
          "contributors"
        ],
        "properties": {
          "timeframe": {
            "type": "string",
            "description": "Membership timeframe, e.g. '2025-2026' or Fall 2025."
          },
          "maintainers": {
            "type": "array",
            "description": "GitHub usernames of maintainers for this timeframe.",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "contributors": {
            "type": "array",
            "description": "GitHub usernames of contributors for this timeframe.",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      },
      "minProperties": 1
    },
    "create-oidc-clients": {
      "type": "boolean",
      "description": "Whether to create OIDC clients for the team.",
      "default": true
    },
    "additionalProperties": false
  },
  "additionalProperties": false,
  "allOf": [
    {
      "$comment": "Require 'website' when 'create-oidc-clients' is missing or true.",
      "if": {
        "anyOf": [
          {
            "not": {
              "required": [
                "create-oidc-clients"
              ]
            }
          },
          {
            "properties": {
              "create-oidc-clients": {
                "const": true
              }
            }
          }
        ]
      },
      "then": {
        "required": [
          "website"
        ]
      }
    }
  ]
}
